APP_NAME="App Revistas API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.apprevistas.xpertiaplus.com

OJS_HTTP_TIMEOUT=20
OJS_HTTP_CONNECT_TIMEOUT=8
OJS_HTTP_RETRY_TIMES=2
OJS_HTTP_RETRY_SLEEP_MS=200
OJS_CACHE_TTL_SECONDS=300

OJS_SOURCE_1_ENABLED=true
OJS_SOURCE_1_SLUG=investigacion
OJS_SOURCE_1_NAME="Investigacion UNITEPC"
OJS_SOURCE_1_BASE_URL=https://investigacion.unitepc.edu.bo/revista
OJS_SOURCE_1_API_BASE_URL=https://investigacion.unitepc.edu.bo/revista/index.php/_/api/v1
OJS_SOURCE_1_SITE_URL=https://investigacion.unitepc.edu.bo/revista/
OJS_SOURCE_1_DRIVER=public_ojs_34
OJS_SOURCE_1_TOKEN=

OJS_SOURCE_2_ENABLED=true
OJS_SOURCE_2_SLUG=g-news
OJS_SOURCE_2_NAME="G-News UNITEPC"
OJS_SOURCE_2_DRIVER=public_ojs_34
OJS_SOURCE_2_BASE_URL=https://g-news.unitepc.edu.bo/revista
OJS_SOURCE_2_API_BASE_URL=
OJS_SOURCE_2_JOURNAL_URL=https://g-news.unitepc.edu.bo/revista/index.php/revista
OJS_SOURCE_2_ARCHIVE_URL=https://g-news.unitepc.edu.bo/revista/index.php/revista/issue/archive
OJS_SOURCE_2_OAI_BASE_URL=https://g-news.unitepc.edu.bo/revista/index.php/revista/oai
OJS_SOURCE_2_TOKEN=

OJS_SOURCE_3_ENABLED=true
OJS_SOURCE_3_SLUG=facefa-eie
OJS_SOURCE_3_NAME="Economía, Innovación y Emprendimiento"
OJS_SOURCE_3_DRIVER=public_ojs_34
OJS_SOURCE_3_BASE_URL=https://investigacionfacefa.unitepc.edu.bo/revistas
OJS_SOURCE_3_API_BASE_URL=
OJS_SOURCE_3_JOURNAL_URL=https://investigacionfacefa.unitepc.edu.bo/revistas/index.php/eie/index
OJS_SOURCE_3_ARCHIVE_URL=https://investigacionfacefa.unitepc.edu.bo/revistas/index.php/eie/issue/archive
OJS_SOURCE_3_OAI_BASE_URL=https://investigacionfacefa.unitepc.edu.bo/revistas/index.php/eie/oai
OJS_SOURCE_3_TOKEN=

FCM_PROJECT_ID=
FCM_CREDENTIALS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=xpertiap_apprevistas
DB_USERNAME=xpertiap_apprevistas
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
