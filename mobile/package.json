{
  "name": "unitepc-revistas-mobile",
  "version": "0.0.1",
  "description": "Aplicacion movil nativa para el ecosistema de revistas UNITEPC",
  "productName": "Revistas UNITEPC",
  "author": "UNITEPC",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "dev": "quasar dev",
    "build": "quasar build",
    "sync:android": "cd src-capacitor && npx cap sync android",
    "build:android": "npm run build && npm run sync:android",
    "apk:debug": "npm run build:android && cd src-capacitor\\android && gradlew.bat assembleDebug",
    "apk:release": "npm run build:android && cd src-capacitor\\android && gradlew.bat assembleRelease",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/file-transfer": "^2.0.4",
    "@capacitor/file-viewer": "^2.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@quasar/extras": "^1.16.4",
    "pdfjs-dist": "^5.6.205",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@quasar/app-vite": "^2.5.1",
    "@types/node": "^22.19.11",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
